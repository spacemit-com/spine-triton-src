+  mlir::LogicalResult
+  matchAndRewrite(amdgpu::ExtractSliceOp op,
+                  PatternRewriter &rewriter) const override {
+    // Try to match preceding Concat op
+    auto concatOp = op.getSource().getDefiningOp<amdgpu::ConcatOp>();
+    if (!concatOp)
+      return failure();
